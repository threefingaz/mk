# Upstash KV credentials (production). Local dev works without these — lib/kv.ts (Task 20) falls back to an in-memory mock.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Unlock threshold for the scoreboard. Defaults to 30 with real KV creds, 5 with
# mock KV (zero-config local dev — easy to exercise the unlock-moment flow with
# a few completions). Override here if needed.
# REVEAL_AT=5
